<% layout('layouts/boilerplate') %>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-7">
                <div class="card shadow-lg border-0 rounded-4">
                    <img src="/images/cv1.jpg" class="card-img-top" alt="Ha Long Bay"
                        style="height: 400px; object-fit: cover;">

                    <div class="card-body p-4">
                        <h2 class="text-center mb-4">Register</h2>
                        <form action="/register" method="POST" class="validated-form" novalidate>
                            <div class="mb-3">
                                <label class="form-label" for="image">Username</label>
                                <input class="form-control" type="text" id="username" name="username" required autofocus>
                                <div class="invalid-feedback">
                                    Please enter your username.
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="email">Email</label>
                                <input class="form-control" type="email" id="email" name="email" required>
                                <div class="invalid-feedback">
                                    Please enter your email.
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="password">Password</label>
                                <input class="form-control" type="password" id="parrword" name="password" required>
                                <div class="invalid-feedback">
                                    Please enter your password.
                                </div>
                            </div>
                            <button class="btn btn-success btn-block">Register</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>