<% layout('layouts/boilerplate') %>
    <h1 class="text-center mb-4">Edit Spot</h1>
    <div class="row">
        <div class="col-6 offset-3">
            <form action="/spots/<%= spot._id %>?_method=PUT" method="POST" enctype="multipart/form-data" novalidate
                class="validated-form">
                <div class="mb-3">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control" type="text" id="title" name="spot[title]" value="<%=spot.title %>"
                        required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="location">Location</label>
                    <input class="form-control" type="text" id="location" name="spot[location]" required
                        value="<%= spot.location %>">
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>



                <div class="mb-3">
                    <label class="form-label" for="price">Spot Price</label>
                    <div class="input-group">
                        <span class="input-group-text" id="basic-addon1">$</span>
                        <input type="text" class="form-control" id="price" placeholder="0.00" aria-label="price"
                            aria-describedby="price-label" name="spot[price]" value="<%= spot.price %>" required>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="description">Description</label>
                    <textarea class="form-control" type="text" id="description" name="spot[description]"
                        required><%= spot.description %></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <div class="custom-file">
                        <input type="file" class="custom-file-input" id="image" name="image" multiple>
                        <label class="custom-file-label form-file-text" for="image">Add more image(s)...</label>
                    </div>
                </div>
                <div class="row">
                    <% spot.images.forEach((img, i)=> { %>
                        <div class="col-md-4 text-center mb-3">
                            <img src="<%= img.thumbnail %>" class="img-thumbnail mb-2">

                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="img-<%= i %>" name="deleteImages[]"
                                    value="<%= img.filename %>">

                                <label class="form-check-label" for="img-<%= i %>">
                                    Delete
                                </label>
                            </div>
                        </div>
                        <% }) %>
                </div>
                <div class="mb-3">
                    <button class="btn btn-info">Update Spot</button>
                </div>

            </form>
            <a href="/spots/<%= spot._id %>">Back to Spot</a>
        </div>
    </div>