<% layout('layouts/boilerplate') %>
<div id="map" style="width: 100%; height: 500px"></div>
    <h1>All Spots</h1>
    <div>
        <a href="/spots/new">Add Spot</a>
    </div>
    <% for (let spot of spots) { %>
        <div class="card" mb-3>
            <div class="row">
                <div class="col-md-4">
                    <img class="img-fluid" alt="" src="<%= spot.images[0].url %>">
                </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= spot.title %>
                        </h5>
                        <p class="card-text">
                            <%= spot.description%>
                        </p>
                        <p class="card-text">
                            <small class="text-muted">
                                <%= spot.location%>
                            </small>
                        </p>
                        <a class="btn btn-primary" href="/spots/<%= spot._id %>">View <%= spot.title %></a>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

            <%- "<script>" %>
                const maptilerApiKey = "<%- process.env.MAPTILER_API_KEY %>";
                const spots = {
                    type: "FeatureCollection",
                    features: <%- JSON.stringify( spots.map(spot=> ({
                        type: "Feature",
                        geometry: spot.geometry,
                        properties: { popUpMarkup: spot?.properties?.popUpMarkup }
                        }))
                        ) %>
                        };
            <%- "</script>" %>

<script src="/javascripts/clusterMap.js"></script>